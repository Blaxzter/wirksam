# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5174
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Full Stack FastAPI Project"
STACK_NAME=full-stack-fastapi-project

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:4173,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"

# Auth0 configuration
AUTH0_DOMAIN=your-domain.eu.auth0.com
AUTH0_AUDIENCE=https://your-audience.dev

# Auth0 Management API (Machine-to-Machine App credentials)
# Create a Machine-to-Machine app in Auth0 Dashboard and authorize it for Management API
AUTH0_CLIENT_ID=EXAMPLE_CLIENT_ID
AUTH0_CLIENT_SECRET=EXAMPLE_CLIENT_SECRET
# Auth0 Management API audience — uses canonical tenant domain, not custom domain
AUTH0_MANAGEMENT_AUDIENCE=https://your-tenant.eu.auth0.com/api/v2/

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=8432
POSTGRES_DB=app
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

SENTRY_DSN=https://your-sentry-dsn

# Web Push (VAPID) — generate keys with:
# cd backend && uv run python -c "from py_vapid import Vapid; from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat; import base64; v = Vapid(); v.generate_keys(); pub = base64.urlsafe_b64encode(v._public_key.public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)).rstrip(b'=').decode(); priv = base64.urlsafe_b64encode(v._private_key.private_numbers().private_value.to_bytes(32, 'big')).rstrip(b'=').decode(); print(f'VAPID_PRIVATE_KEY={priv}'); print(f'VAPID_PUBLIC_KEY={pub}')"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# Telegram Bot — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Legal / Impressum (injected at runtime into frontend config.js)
LEGAL_NAME=
LEGAL_ADDRESS=
LEGAL_CITY=
LEGAL_EMAIL=
LEGAL_PHONE=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# API domain (used for Traefik routing of backend and frontend build arg)
API_DOMAIN=api.localhost
