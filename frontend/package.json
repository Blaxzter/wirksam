{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:e2e": "node --env-file-if-exists=.env ./node_modules/@playwright/test/cli.js test",
    "test:e2e:debug": "node --env-file-if-exists=.env ./node_modules/@playwright/test/cli.js test --debug",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit --project tsconfig.app.json",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "generate-client": "openapi-ts -s",
    "generate-changelog": "tsx scripts/generate-changelog.ts"
  },
  "dependencies": {
    "@auth0/auth0-vue": "^2.4.0",
    "@hookform/resolvers": "^5.1.1",
    "@internationalized/date": "^3.12.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/vue-table": "^8.21.3",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^13.5.0",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-vue": "^8.6.0",
    "flag-icons": "^7.5.0",
    "lucide-vue-next": "^0.525.0",
    "motion-v": "^2.2.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.4.0",
    "simple-icons": "^15.7.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.18",
    "vue-i18n": "11",
    "vue-router": "^4.5.1",
    "vue-sonner": "^2.0.2",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.80.1",
    "@playwright/test": "^1.54.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@tsconfig/node22": "^22.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.1.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.31.0",
    "eslint-plugin-playwright": "^2.2.0",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.5.1",
    "markdown-it": "^14.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^7.7.7",
    "vite-svg-loader": "^5.1.0",
    "vue-tsc": "^3.0.4"
  },
  "packageManager": "pnpm@10.30.3"
}
